{
  "name": "ai-studio",
  "version": "1.0.0",
  "description": "AI Studio with Barada API Backend",
  "main": "server.js",
  "scripts": {
    "start:api": "node server.js",
    "start:desktop": "npm start --prefix wakil-desktop",
    "dev:web": "npm run dev --prefix wakil-ai",
    "build:web": "npm run build --prefix wakil-ai",
    "install:all": "npm install && npm install --prefix wakil-desktop && npm install --prefix wakil-ai"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0"
  }
}
